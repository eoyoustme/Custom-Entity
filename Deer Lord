-- Đặt vị trí ban đầu phía sau lưng người chơi
local hrp = Character:WaitForChild("HumanoidRootPart", 5)
if hrp then
	entity.CFrame = hrp.CFrame * CFrame.new(0, 0, 200)
end

local function followPlayer(dt)
	local currentHrp = Character:FindFirstChild("HumanoidRootPart")
	if not currentHrp then
		return
	end

	local currentPos = entity.Position
	local targetPos = currentHrp.Position
	local distance = (targetPos - currentPos).Magnitude

	-- Tránh lỗi NaN nếu entity trùng vị trí với HRP
	if distance > 0.5 then
		local direction = (targetPos - currentPos).Unit
		local newPos = currentPos + (direction * Speed * dt)
		entity.CFrame = CFrame.lookAt(newPos, targetPos)
	end
end

-- Cập nhật mỗi khung hình
local connection
connection = RunService.RenderStepped:Connect(function(dt)
	if not entity or not entity.Parent then
		if connection then connection:Disconnect() end
		return
	end

	followPlayer(dt)
	s:PivotTo(entity.CFrame)
end)

task.spawn(function()
	local fullBody = entity:FindFirstChild("FullBody")
	local attachment = entity:FindFirstChild("Attachment")

	if not fullBody or not attachment then
		warn("Không tìm thấy FullBody hoặc Attachment")
		return
	end

	local Body = fullBody:FindFirstChild("Body")
	local Hay = attachment:FindFirstChild("Hay")

	if not Body or not Hay then
		warn("Không tìm thấy Body hoặc Hay")
		return
	end

	while task.wait(0.3) do
		local char = player.Character
		if not char then
			continue
		end

		local hum = char:FindFirstChildWhichIsA("Humanoid")
		local currentHrp = char:FindFirstChild("HumanoidRootPart")

		if hum and currentHrp and entity and entity.Parent then
			local distance = (currentHrp.Position - entity.Position).Magnitude

			if distance <= 40 then
				Body.Enabled = false
				Hay.Enabled = true
			elseif distance <= 200 then
				Body.Enabled = true
				Hay.Enabled = false
			else
				Body.Enabled = false
				Hay.Enabled = false
			end
		end
	end
end)

