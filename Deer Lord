task.spawn(function()
	while task.wait() do
		if death and entity and entity.Parent then
			local currentHrp = Character:FindFirstChild("HumanoidRootPart")
			local hum = Character:FindFirstChildOfClass("Humanoid")

			if currentHrp and hum then
				local direction = (currentHrp.Position - entity.Position).Unit * 9
				local result = workspace:Raycast(entity.Position, direction)

				if result and result.Instance:IsDescendantOf(Character) then
					if not Character:GetAttribute("Hiding") then
						if not attacking then
							attacking = true
							hum:TakeDamage(30)

							if Random.new():NextInteger(1, 2) == 1 then
								PlayJumpscare1()
							else
								PlayJumpscare2()
							end

							if hum.Health <= 0 then
								local stats = game.ReplicatedStorage:FindFirstChild("GameStats")
								if stats then
									local playerStats = stats:FindFirstChild("Player_" .. player.Name)
									if playerStats
										and playerStats:FindFirstChild("Total")
										and playerStats.Total:FindFirstChild("DeathCause") then

										playerStats.Total.DeathCause.Value = "Deer Lord"
									end
								end
							end

							task.wait(2)
							attacking = false
						end
					end
				end
			end
		end
	end
end)

