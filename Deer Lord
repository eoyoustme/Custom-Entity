)

local function followPlayer()
	local hrp = Character:FindFirstChild("HumanoidRootPart")
	if not hrp then
		return
	end

	local direction = (hrp.Position - entity.Position).Unit

	entity.AssemblyLinearVelocity = direction * Speed
	entity.CFrame = CFrame.lookAt(entity.Position, hrp.Position)
end

RunService.RenderStepped:Connect(function()

	if not entity.Parent then
		return
	end

	followPlayer()

	if s.PrimaryPart then
		s:PivotTo(entity.CFrame)
	else
		s:PivotTo(entity.CFrame)
	end

end)

