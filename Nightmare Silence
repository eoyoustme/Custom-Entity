-- Các Module điều khiển
local Modules = {
	Module_Events = require(ReplicatedStorage.ModulesClient.Module_Events :: ModuleScript),
	Main_Game = require(PlayerGui.MainUI.Initiator.Main_Game :: ModuleScript)
