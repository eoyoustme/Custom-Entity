-- Hàm lấy phòng hiện tại dựa trên GameData
local function GetRoom()
	local gruh = workspace:FindFirstChild("CurrentRooms")
	local gameData = ReplicatedStorage:FindFirstChild("GameData")
	local latestRoom = gameData and gameData:FindFirstChild("LatestRoom")

	if gruh and latestRoom then
		return gruh:FindFirstChild(tostring(latestRoom.Value))
	end
	return nil
end

-- Hàm lấy phòng mới nhất hoặc phòng hiện tại theo Attribute
local function GetCurrentRoom(latest: boolean): Model?
	if latest then
		local rooms = CurrentRooms:GetChildren()
		return rooms[#rooms]
	end
	local roomAttr = LocalPlayer:GetAttribute("CurrentRoom")
	return roomAttr and CurrentRooms:FindFirstChild(roomAttr) or nil
end

-- Hàm sửa đèn trong phòng
local function FixRoomLights(room: Model)
	local roomEntrance = room:FindFirstChild("RoomEntrance")
	if not roomEntrance then return end

	-- Xóa các mảnh vỡ kính cũ trong Camera
	for _, c in next, Camera:GetChildren() do
		if c.Name == "Piece" then
			c:Destroy()
		end
	end
end -- <- SỬA LỖI 1: Đã thêm 'end' để đóng hàm FixRoomLights một cách hợp lệ

-- Tải và khởi tạo Entity (Sử dụng pcall an toàn cho Executor/Plugin)
local success, assets = pcall(function()
	return game:GetObjects("rbxassetid://133375815714221")
end)

if not success or not assets or #assets == 0 then
	warn("⚠️ Không thể tải được Asset Entity! Kiểm tra lại ID hoặc quyền hạn Script.")
	return
end

local s = assets[1]
s.Parent = workspace

local entity = s:FindFirstChildWhichIsA("BasePart")
if not entity then
	warn("⚠️ Không tìm thấy BasePart nào bên trong Asset để làm Entity!")
	return
end

local point = Instance.new("PointLight")
point.Parent = entity
point.Color = Color3.fromRGB(255,0,0)
point.Range = 20
point.Brightness = 10


local Sound = Instance.new("Sound")
Sound.Parent = entity
Sound.SoundId = "rbxassetid://9113731969"
Sound.Volume = 5
Sound.PlaybackSpeed = 2.5
Sound.RollOffMinDistance = 100
Sound.RollOffMaxDistance = 200
Sound:Play()


-- Kiểm tra phòng hợp lệ trước khi dịch chuyển
local currentRoom = GetRoom()
if currentRoom then
	local entrance = currentRoom:WaitForChild("RoomEntrance", 5)
	if entrance then
		entity.CFrame = entrance.CFrame * CFrame.new(0, 3, -25)
	end
else
	warn("⚠️ Không tìm thấy phòng hiện tại để dịch chuyển Entity.")
end

-- Xử lý hiệu ứng đèn giật/nổ dựa theo cấu hình Config của Entity
local config = entity:FindFirstChild("Config")
local latestRoom = GetCurrentRoom(true)

if currentRoom and currentRoom ~= latestRoom and config and config:FindFirstChild("Lights") then
	if config.Lights:FindFirstChild("Shatter") and config.Lights.Shatter.Value then
		Modules.Module_Events.shatter(currentRoom)
	elseif config.Lights:FindFirstChild("Repair") and config.Lights.Repair.Value then
		FixRoomLights(currentRoom)
	end
end

